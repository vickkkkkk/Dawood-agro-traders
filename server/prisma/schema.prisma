generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("CASHIER") // ADMIN, MANAGER, CASHIER
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bills Bill[]
  returnRecords ReturnRecord[]

  @@map("users")
}

model Category {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  products Product[]

  @@map("categories")
}

model Product {
  id            Int       @id @default(autoincrement())
  name          String
  sku           String    @unique
  categoryId    Int
  purchasePrice Float
  salePrice     Float
  stockQty      Float     @default(0)
  unit          String    @default("bags")
  lowStockAlert Float     @default(10)
  expiryDate    DateTime?
  batchNo       String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  category      Category       @relation(fields: [categoryId], references: [id])
  billItems     BillItem[]
  purchaseItems PurchaseItem[]

  @@map("products")
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  address   String?
  company   String?
  createdAt DateTime @default(now())

  purchases Purchase[]
  liabilities Liability[]
  returnRecords ReturnRecord[]

  @@map("suppliers")
}

model Customer {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String?  @unique
  address       String?
  creditBalance Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bills              Bill[]
  creditTransactions CreditTransaction[]
  returnRecords      ReturnRecord[]

  @@map("customers")
}

model Bill {
  id            Int           @id @default(autoincrement())
  billNo        String        @unique
  customerId    Int?
  userId        Int
  subtotal      Float
  discount      Float         @default(0)
  total         Float
  paymentMethod String        // CASH, JAZZCASH, EASYPAISA, BANK_TRANSFER, CREDIT
  paymentStatus String        // PAID, CREDIT
  amountPaid    Float
  creditAmount  Float         @default(0)
  isVoid        Boolean       @default(false)
  hasReturns    Boolean       @default(false)
  billDate      DateTime      @default(now())
  createdAt     DateTime      @default(now())

  customer Customer?  @relation(fields: [customerId], references: [id])
  user     User       @relation(fields: [userId], references: [id])
  items    BillItem[]
  creditTransactions CreditTransaction[]

  @@map("bills")
}

model BillItem {
  id        Int     @id @default(autoincrement())
  billId    Int
  productId Int
  quantity  Float
  returnedQuantity Float @default(0)
  unitPrice Float
  total     Float
  purchasePrice Float   @default(0)

  bill    Bill    @relation(fields: [billId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("bill_items")
}

model Purchase {
  id                     Int            @id @default(autoincrement())
  grnNo                  String         @unique
  supplierId             Int
  userId                 Int
  total                  Float          // Items total cost
  status                 String         @default("RECEIVED") // RECEIVED, PENDING
  hasReturns             Boolean        @default(false)
  purchaseDate           DateTime       @default(now())
  createdAt              DateTime       @default(now())

  // New GRN & Logistics fields
  purchaseOrderRef       String?
  grandTotal             Float          @default(0)
  paymentMethod          String         @default("CASH") // CASH, BANK, LIABILITY
  biltyNo                String?
  transporterName        String?
  transportCost          Float          @default(0)
  biltyDate              DateTime?
  transportPaymentMethod String?        // CASH, BANK, LIABILITY

  supplier               Supplier       @relation(fields: [supplierId], references: [id])
  items                  PurchaseItem[]
  liability              Liability?

  @@map("purchases")
}

model PurchaseItem {
  id         Int       @id @default(autoincrement())
  purchaseId Int
  productId  Int
  quantity   Float
  returnedQuantity Float @default(0)
  unitPrice  Float     // Cost price
  total      Float
  salePrice  Float     @default(0) // Selling price (for margin tracking)
  batchNo    String?
  expiryDate DateTime?

  purchase   Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product    Product   @relation(fields: [productId], references: [id])

  @@map("purchase_items")
}

model Liability {
  id               Int                @id @default(autoincrement())
  grnNo            String             @unique
  purchaseId       Int                @unique
  supplierId       Int
  totalAmount      Float
  paidAmount       Float              @default(0)
  remainingBalance Float              @default(0)
  dueDate          DateTime?
  status           String             @default("UNPAID") // UNPAID, PARTIAL, PAID
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  purchase         Purchase           @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  supplier         Supplier           @relation(fields: [supplierId], references: [id])
  payments         LiabilityPayment[]

  @@map("liabilities")
}

model LiabilityPayment {
  id            Int        @id @default(autoincrement())
  liabilityId   Int
  amount        Float
  paymentMethod String     // CASH, BANK
  paymentDate   DateTime   @default(now())
  description   String?
  createdAt     DateTime   @default(now())

  liability     Liability  @relation(fields: [liabilityId], references: [id], onDelete: Cascade)

  @@map("liability_payments")
}

model CreditTransaction {
  id              Int        @id @default(autoincrement())
  customerId      Int
  billId          Int?
  type            String     // CREDIT, PAYMENT
  amount          Float
  description     String?
  paymentMethod   String?
  transactionDate DateTime   @default(now())
  createdAt       DateTime   @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
  bill     Bill?    @relation(fields: [billId], references: [id])

  @@map("credit_transactions")
}

model CashTransaction {
  id               Int      @id @default(autoincrement())
  type             String   // INFLOW, EXPENSE, BANK_TRANSFER, PARTY_PAYMENT, LIABILITY, GOODS_PURCHASE
  amount           Float
  date             DateTime @default(now())
  description      String?  // Reference note / notes
  paymentMethod    String   @default("CASH") // CASH, BANK

  // Subtype-specific fields
  category         String?  // Expense category: Rent, Salary, Utilities, Maintenance, etc.
  partyName        String?  // Party Payment
  liabilityName    String?  // Liability Payment
  remainingBalance Float?   // Liability Payment
  itemName         String?  // Purchase of Goods
  quantity         Float?   // Purchase of Goods
  unitPrice        Float?   // Purchase of Goods

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("cash_transactions")
}

model ReturnRecord {
  id            Int                @id @default(autoincrement())
  returnNo      String             @unique
  returnDate    DateTime           @default(now())
  type          String             // SALE, PURCHASE
  subType       String             // FULL, PARTIAL
  referenceNo   String             // Original Bill.billNo or Purchase.grnNo
  billId        Int?
  purchaseId    Int?
  customerId    Int?
  supplierId    Int?
  reason        String?
  reasonDetails String?
  refundMethod  String             // CASH, CREDIT, ONLINE, NONE
  netAmount     Float
  userId        Int

  customer      Customer?          @relation(fields: [customerId], references: [id])
  supplier      Supplier?          @relation(fields: [supplierId], references: [id])
  user          User               @relation(fields: [userId], references: [id])
  items         ReturnRecordItem[]

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@map("return_records")
}

model ReturnRecordItem {
  id             Int          @id @default(autoincrement())
  returnRecordId Int
  productId      Int
  productName    String
  quantity       Float
  unitPrice      Float
  total          Float

  returnRecord   ReturnRecord @relation(fields: [returnRecordId], references: [id], onDelete: Cascade)

  @@map("return_record_items")
}

